# IDE e configurazioni locali
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# Tooling Node opzionale per il server locale
node_modules/
.npm/
.pnpm-store/
.yarn/
.local-dev/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dati personali dell'organizer
# I file personali possono avere qualunque nome: la protezione è basata
# sulla cartella, non su un nome di file convenzionale.
data/user/*
!data/user/README.md
data/private/*
!data/private/README.md

# Esportazioni e backup locali
exports/*
!exports/.gitkeep
backups/*
!backups/.gitkeep
*.personal.json
*.private.json
*.local.json
*.secret.json
organizer-data-*.json
piano-studio-*.json

# Segreti e configurazioni locali
.env
.env.*
!.env.example

# File temporanei del sistema operativo e log
.DS_Store
Thumbs.db
*.log
